{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [

    {
      "type": "row",
      "title": "CPU",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU Usage Rate per Pod",
      "description": "CPU cores consumed per pod (rate of cpu_usage_seconds_total).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "cores", "custom": { "lineWidth": 2, "fillOpacity": 6 } },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean","max","lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", pod=~\"$pod\", container!=\"\", container!=\"POD\"}[$__rate_interval])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Usage % of Limit per Pod",
      "description": "CPU usage as a percentage of the configured limit. >80% = risk of throttling.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 6 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean","max","lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", pod=~\"$pod\", container!=\"\", container!=\"POD\"}[$__rate_interval])) by (pod) / sum(kube_pod_container_resource_limits{namespace=~\"$namespace\", pod=~\"$pod\", resource=\"cpu\"}) by (pod) * 100",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Memory Usage per Pod",
      "description": "Working set memory (RSS + file cache) consumed per pod.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 6 } },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean","max","lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"$namespace\", pod=~\"$pod\", container!=\"\", container!=\"POD\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage % of Limit per Pod",
      "description": "Memory usage as % of limit. >80% = OOMKill risk.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 6 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean","max","lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"$namespace\", pod=~\"$pod\", container!=\"\", container!=\"POD\"}) by (pod) / sum(kube_pod_container_resource_limits{namespace=~\"$namespace\", pod=~\"$pod\", resource=\"memory\"}) by (pod) * 100",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "Persistent Volumes",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },

    {
      "type": "row",
      "title": "Pod Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Pod Restart Count (CrashLoopBackOff detector)",
      "description": "Total restarts per pod. Sustained increase = CrashLoopBackOff risk.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 6 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["max","lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=~\"$namespace\", pod=~\"$pod\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pod Readiness Ratio per Deployment",
      "description": "Ready pods / desired pods. Drop below 1.0 = traffic disruption.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean","min","lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(kube_deployment_status_replicas_ready{namespace=~\"$namespace\"}) by (deployment) / sum(kube_deployment_status_replicas{namespace=~\"$namespace\"}) by (deployment)",
          "legendFormat": "{{deployment}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pending / Unschedulable Pods",
      "description": "Pods stuck in Pending phase — early cluster pressure or resource quota signal.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["max","lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{namespace=~\"$namespace\", phase=\"Pending\"}) by (namespace)",
          "legendFormat": "Pending — {{namespace}}",
          "refId": "A"
        },
        {
          "expr": "count(kube_pod_status_unschedulable{namespace=~\"$namespace\"} == 1) by (namespace)",
          "legendFormat": "Unschedulable — {{namespace}}",
          "refId": "B"
        }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["kubernetes", "workload"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "hide": 0
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kube_pod_info, namespace)",
        "query": { "query": "label_values(kube_pod_info, namespace)", "refId": "StandardVariableQuery" },
        "label": "Namespace",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kube_pod_info{namespace=~\"$namespace\"}, pod)",
        "query": { "query": "label_values(kube_pod_info{namespace=~\"$namespace\"}, pod)", "refId": "StandardVariableQuery" },
        "label": "Pod",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "2 — Kubernetes Workload",
  "uid": "k8s-workload-v2",
  "version": 1
}
