      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"sock-shop\", container=\"catalogue\", image!=\"\", job=\"kubelet\"} / on(pod, namespace) kube_pod_container_resource_limits{namespace=\"sock-shop\", container=\"catalogue\", resource=\"memory\"}",
          "legendFormat": "catalogue",
          "refId": "A"
