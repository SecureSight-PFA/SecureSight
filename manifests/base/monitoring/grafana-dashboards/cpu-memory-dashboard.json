{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "CPU Usage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "cores"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"sock-shop\", container=\"catalogue\", image!=\"\", job=\"kubelet\"}[5m])",
          "legendFormat": "catalogue",
          "refId": "A"
        },
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"sock-shop\", container=\"user\", image!=\"\", job=\"kubelet\"}[5m])",
          "legendFormat": "user",
          "refId": "B"
        },
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"sock-shop\", container=\"orders\", image!=\"\", job=\"kubelet\"}[5m])",
          "legendFormat": "orders",
          "refId": "C"
        },
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"sock-shop\", container=\"front-end\", image!=\"\", job=\"kubelet\"}[5m])",
          "legendFormat": "frontend",
          "refId": "D"
        }
      ],
      "title": "CPU Usage Rate (all services)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percentunit",
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"sock-shop\", container=\"catalogue\", image!=\"\", job=\"kubelet\"}[5m]) / on(pod, namespace) kube_pod_container_resource_limits{namespace=\"sock-shop\", container=\"catalogue\", resource=\"cpu\"}",
          "legendFormat": "catalogue",
          "refId": "A"
        },
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"sock-shop\", container=\"user\", image!=\"\", job=\"kubelet\"}[5m]) / on(pod, namespace) kube_pod_container_resource_limits{namespace=\"sock-shop\", container=\"user\", resource=\"cpu\"}",
          "legendFormat": "user",
          "refId": "B"
        },
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"sock-shop\", container=\"orders\", image!=\"\", job=\"kubelet\"}[5m]) / on(pod, namespace) kube_pod_container_resource_limits{namespace=\"sock-shop\", container=\"orders\", resource=\"cpu\"}",
          "legendFormat": "orders",
          "refId": "C"
        },
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"sock-shop\", container=\"front-end\", image!=\"\", job=\"kubelet\"}[5m]) / on(pod, namespace) kube_pod_container_resource_limits{namespace=\"sock-shop\", container=\"front-end\", resource=\"cpu\"}",
          "legendFormat": "frontend",
          "refId": "D"
        }
      ],
      "title": "CPU Usage % of Limit",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Memory Usage",
