        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"sock-shop\", container=\"catalogue\", image!=\"\", job=\"kubelet\"}",
