{
  "title": "Sock Shop — Latency (App Only)",
  "uid": "sockshop-latency-clean",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(request_duration_seconds_bucket{namespace=\"sock-shop\", name=~\"carts|catalogue|orders|front-end|user|payment|shipping|queue-master\"}[5m])) by (le, name))",
          "legendFormat": "p50 {{name}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(request_duration_seconds_bucket{namespace=\"sock-shop\", name=~\"carts|catalogue|orders|front-end|user|payment|shipping|queue-master\"}[5m])) by (le, name))",
          "legendFormat": "p95 {{name}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(request_duration_seconds_bucket{namespace=\"sock-shop\", name=~\"carts|catalogue|orders|front-end|user|payment|shipping|queue-master\"}[5m])) by (le, name))",
          "legendFormat": "p99 {{name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate (RPS)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(request_duration_seconds_count{namespace=\"sock-shop\", name=~\"carts|catalogue|orders|front-end|user|payment|shipping|queue-master\"}[5m])) by (name)",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Current p99 Latency",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(request_duration_seconds_bucket{namespace=\"sock-shop\", name=~\"carts|catalogue|orders|front-end|user|payment|shipping|queue-master\"}[5m])) by (le, name))",
          "legendFormat": "{{name}}"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  }
}