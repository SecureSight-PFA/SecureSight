{
  "title": "Sock Shop — Errors & Restarts (App Only)",
  "uid": "sockshop-errors-restarts-clean",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Container Restarts (per hour)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"sock-shop\", container=~\"carts|catalogue|orders|front-end|user|payment|shipping|queue-master\"}[1h])) by (container)",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Restarts (lifetime)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"sock-shop\", container=~\"carts|catalogue|orders|front-end|user|payment|shipping|queue-master\"}) by (container)",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx Error Rate (RPS)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(request_duration_seconds_count{namespace=\"sock-shop\", name=~\"carts|catalogue|orders|front-end|user|payment|shipping|queue-master\", status_code=~\"5..\"}[5m])) by (name)",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate % (5xx / total)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(request_duration_seconds_count{namespace=\"sock-shop\", name=~\"carts|catalogue|orders|front-end|user|payment|shipping|queue-master\", status_code=~\"5..\"}[5m])) by (name) / sum(rate(request_duration_seconds_count{namespace=\"sock-shop\", name=~\"carts|catalogue|orders|front-end|user|payment|shipping|queue-master\"}[5m])) by (name)",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Running Pods Count (per service)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{namespace=\"sock-shop\", phase=\"Running\", pod=~\"carts.*|catalogue.*|orders.*|front-end.*|user.*|payment.*|shipping.*|queue-master.*\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Containers Waiting (CrashLoopBackOff etc.)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_waiting_reason{namespace=\"sock-shop\", container=~\"carts|catalogue|orders|front-end|user|payment|shipping|queue-master\"}) by (container, reason)",
          "legendFormat": "{{container}} - {{reason}}"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  }
}